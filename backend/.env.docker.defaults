# Defaults for docker-compose when no .env or .env.local is present (in-container Postgres).
# env_file order: this file, then .env, then .env.local (later overrides).
# Override with .env.local (e.g. Supabase URLs, JWT, CORS, Razorpay) or .env as needed.
BILLING_DATABASE_URL=postgresql+asyncpg://billing_user:billing_pass@billing_db:5432/billing_db
TEACHING_DATABASE_URL=postgresql+asyncpg://teaching_user:teaching_pass@teaching_db:5432/teaching_db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,https://school.axpocreation.com,https://billing.axpocreation.com,https://axposerver.axpocreation.com,http://axposerver.axpocreation.com
