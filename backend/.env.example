# Billing DB (Supabase or any Postgres)
# Supabase: Dashboard → Project Settings → Database → Connection string (URI).
# Use "Transaction" pooler, then change prefix to postgresql+asyncpg://
# Example: postgresql+asyncpg://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
BILLING_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/billing_db

# Teaching DB (same Supabase project = same URL; or separate Postgres)
TEACHING_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/teaching_db

# JWT
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookies (set COOKIE_SECURE=false for localhost)
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS (comma-separated origins). Required for frontends that call this API.
# Production frontends: https://school.axpocreation.com, https://billing.axpocreation.com
# Local dev: http://localhost:5173, http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://school.axpocreation.com,https://billing.axpocreation.com
