# Backend API (optional). When set, teaching uses the backend instead of Supabase.
# Backend origin only (client appends /teaching/api/v1)
# VITE_TEACHING_API_URL=http://localhost:8000

# Supabase (teaching app)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Gemini API – for "Quick Add Students" natural language parsing (Students page).
# Get a key at https://aistudio.google.com/apikey (free tier has rate limits).
# If unset, the app falls back to rule-based parsing.
VITE_GEMINI_API_KEY=

# Optional: override model if the default fails (e.g. "model not found").
# VITE_GEMINI_MODEL=gemini-2.0-flash

# OpenAI API – for Axpo Assistant when using OpenAI as LLM.
# Get a key at https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=
# Optional: model (default gpt-4o-mini). Examples: gpt-4o, gpt-4o-mini
# VITE_OPENAI_MODEL=gpt-4o-mini

# Optional: prefer one provider when both keys are set. Values: gemini | openai
# VITE_LLM_PROVIDER=openai
