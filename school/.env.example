# Backend API (optional). When set, teaching uses the backend instead of Supabase.
# Base URL only (client appends /teaching/api/v1)
# Local:  VITE_TEACHING_API_URL=https://localhost:8001/axpo/api
# Prod:   VITE_TEACHING_API_URL=https://axposerver.axpocreation.com/axpo/api
# (Production builds default to https://axposerver.axpocreation.com/axpo/api when unset.)
# VITE_TEACHING_API_URL=https://localhost:8001/axpo/api
# VITE_TEACHING_API_URL=https://axposerver.axpocreation.com/axpo/api

# Supabase (teaching app)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenRouter API – for Axpo Assistant (only when NOT using Teaching API / Supabase-only mode).
# When VITE_TEACHING_API_URL is set, AI is provided by the backend (configure OPENROUTER_* there).
# Get a key at https://openrouter.ai/keys
# VITE_OPENROUTER_API_KEY=

# Optional: model (default google/gemini-2.0-flash)
# VITE_OPENROUTER_MODEL=google/gemini-2.0-flash
