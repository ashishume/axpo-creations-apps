# Backend API (optional). When set, teaching uses the backend instead of Supabase.
# Backend origin only (client appends /teaching/api/v1)
# Dev: VITE_TEACHING_API_URL=http://localhost:8000
# Production builds default to https://server.axpocreation.com when unset.
# VITE_TEACHING_API_URL=https://server.axpocreation.com

# Supabase (teaching app)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenRouter API – for Axpo Assistant and natural language parsing (e.g. Quick Add Students).
# Get a key at https://openrouter.ai/keys
# When unset, Axpo Assistant and LLM-based parsing are disabled.
# VITE_OPENROUTER_API_KEY=

# Optional: model (default google/gemini-2.0-flash). Examples: google/gemini-2.0-flash, openai/gpt-4o-mini
# VITE_OPENROUTER_MODEL=google/gemini-2.0-flash
