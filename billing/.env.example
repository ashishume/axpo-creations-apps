# Backend API (optional). When set, billing uses the backend instead of Supabase.
# Base URL only (client appends /billing/api/v1)
# Local:  VITE_BILLING_API_URL=https://localhost:8001/axpo/api
# Prod:   VITE_BILLING_API_URL=https://axposerver.axpocreation.com/axpo/api
# (Production builds default to https://axposerver.axpocreation.com/axpo/api when unset.)
# VITE_BILLING_API_URL=https://localhost:8001/axpo/api
# VITE_BILLING_API_URL=https://axposerver.axpocreation.com/axpo/api

# Supabase (required when not using backend API)
# From: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
