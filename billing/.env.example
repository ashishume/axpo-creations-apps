# Backend API (optional). When set, billing uses the backend instead of Supabase.
# Backend origin only (client appends /billing/api/v1)
# Dev: VITE_BILLING_API_URL=http://localhost:8000
# Production builds default to https://server.axpocreation.com when unset.
# VITE_BILLING_API_URL=https://server.axpocreation.com

# Supabase (required when not using backend API)
# From: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
